{
  "name": "tournament-manager",
  "version": "0.1.0",
  "description": "Badminton tournament schedule manager desktop application",
  "author": "Tournament Manager",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder --dir",
    "build:installer": "tsc && vite build && electron-builder",
    "preview": "vite preview",
    "electron:dev": "vite build && electron ."
  },
  "build": {
    "appId": "com.tournament-manager.app",
    "productName": "Tournament Manager",
    "win": {
      "target": "dir",
      "sign": false,
      "signAndEditExecutable": false
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ]
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tanstack/react-query": "^5.62.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0"
  }
}
